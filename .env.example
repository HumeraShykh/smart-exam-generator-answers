# Copy to ".env":  cp .env.example .env

# --- Option A: OpenAI (paid / quota) ---
# EXAMGEN_OPENAI_API_KEY=sk-...
# EXAMGEN_LLM_MODEL=gpt-4o-mini
# EXAMGEN_EMBEDDING_MODEL=text-embedding-3-small

# --- Option B: Groq (free LLM) + Google (free embeddings) — best “no quota” setup ---
# Groq: https://console.groq.com/keys   |   Google: https://aistudio.google.com/app/apikey
EXAMGEN_LLM_BASE_URL=https://api.groq.com/openai/v1
EXAMGEN_LLM_API_KEY=gsk-replace-with-your-groq-key
EXAMGEN_LLM_MODEL=llama-3.3-70b-versatile
# Google path (optional):
# GOOGLE_API_KEY=
# EXAMGEN_EMBEDDINGS_MODE=google

# Hugging Face Inference embeddings (recommended with Groq):
EXAMGEN_EMBEDDINGS_MODE=huggingface_api
# Paste REAL token from https://huggingface.co/settings/tokens (not "hf_replace...")
# Classic: Read | Fine-grained: enable "Make calls to Inference Providers / serverless Inference API"
HF_TOKEN=

# If both GOOGLE_API_KEY and HF_TOKEN exist with Groq, Google is used first.
# To force Hugging Face only: EXAMGEN_EMBEDDINGS_MODE=huggingface_api and remove GOOGLE_API_KEY.

# --- Option D: Groq + local CPU embeddings (needs working PyTorch; often broken on Mac) ---
# EXAMGEN_EMBEDDINGS_MODE=local
# pip install sentence-transformers

# --- LM Studio (local GPU) ---
# EXAMGEN_OPENAI_BASE_URL=http://localhost:1234/v1
# EXAMGEN_OPENAI_API_KEY=lm-studio
